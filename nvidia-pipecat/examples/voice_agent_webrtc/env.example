# # Example: https://integrate.api.nvidia.com/v1 (cloud) or http://localhost:8000/v1 (local NIM)
# #NVIDIA_LLM_URL=
# NVIDIA_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
